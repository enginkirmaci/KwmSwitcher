<Window
    x:Class="KwmSwitcher.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:KwmSwitcher.ViewModels"
    Title="KWM Switcher"
    Width="440"
    Height="220"
    d:DesignHeight="300"
    d:DesignWidth="400"
    x:DataType="vm:MainWindowViewModel"
    CanResize="False"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,12"
            Spacing="4">
            <TextBlock
                FontSize="20"
                FontWeight="Bold"
                Text="KWM Switcher" />
            <TextBlock
                Foreground="Gray"
                Text="{Binding StatusText}"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            VerticalAlignment="Center"
            Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="Active:" />
                <TextBlock VerticalAlignment="Center" Text="{Binding ActiveLabel}" />
            </StackPanel>
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                Padding="16,8"
                Command="{Binding SwitchToLocalCommand}"
                Content="Switch to Local" />
            <Button
                Padding="16,8"
                Command="{Binding SwitchToRemoteCommand}"
                Content="Switch to Remote" />
            <Button
                Margin="8,0,0,0"
                Padding="16,8"
                Command="{Binding OpenSettingsCommand}"
                Content="Settings" />
        </StackPanel>
    </Grid>

</Window>
