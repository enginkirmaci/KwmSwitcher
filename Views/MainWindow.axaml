<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KwmSwitcher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
        x:Class="KwmSwitcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="KWM Switcher"
        Width="380" Height="220"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="KWM Switcher" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="Gray"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Active:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ActiveLabel}" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Button Content="Switch to Local" Command="{Binding SwitchToLocalCommand}" Padding="16,8"/>
            <Button Content="Switch to Remote" Command="{Binding SwitchToRemoteCommand}" Padding="16,8"/>
        </StackPanel>
    </Grid>

</Window>
