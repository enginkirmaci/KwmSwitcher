<Window
    x:Class="KwmSwitcher.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:KwmSwitcher.ViewModels"
    Title=""
    Width="440"
    Height="280"
    d:DesignHeight="350"
    d:DesignWidth="440"
    x:DataType="vm:MainWindowViewModel"
    CanResize="False"
    ExtendClientAreaToDecorationsHint="True"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Background="{DynamicResource ContentBackgroundBrush}" RowDefinitions="38,*">

        <Border
            Grid.Row="0"
            Background="{DynamicResource TitleBarBackgroundBrush}"
            BorderBrush="{DynamicResource TitleBarBorderBrush}"
            BorderThickness="0,0,0,1"
            IsHitTestVisible="True"
            PointerPressed="TitleBar_PointerPressed">
            <DockPanel Margin="14,0" VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SubtitleForegroundBrush}"
                    Text="KWM Switcher" />
            </DockPanel>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="20"
            RowDefinitions="Auto,*,Auto">

            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,12"
                Spacing="4">
                <TextBlock
                    Foreground="{DynamicResource MutedForegroundBrush}"
                    Text="{Binding StatusText}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                VerticalAlignment="Center"
                Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource BodyForegroundBrush}"
                        Text="Active:" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource BodyForegroundBrush}"
                        Text="{Binding ActiveLabel}" />
                </StackPanel>
            </StackPanel>

            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Padding="16,8"
                    Command="{Binding SwitchToLocalCommand}"
                    Content="Switch to Local" />
                <Button
                    Padding="16,8"
                    Command="{Binding SwitchToRemoteCommand}"
                    Content="Switch to Remote" />
                <Button
                    Margin="8,0,0,0"
                    Padding="16,8"
                    Command="{Binding OpenSettingsCommand}"
                    Content="Settings" />
            </StackPanel>
        </Grid>
    </Grid>

</Window>
