<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KwmSwitcher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="500"
        x:Class="KwmSwitcher.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="KWM Switcher - Settings"
        Width="500" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Monitor Input Sources" FontWeight="SemiBold" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Local (this machine):" Width="160" VerticalAlignment="Center"/>
                        <ComboBox Width="180"
                                  ItemsSource="{Binding InputSources}"
                                  SelectedItem="{Binding SelectedLocalInput}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:InputSourceOption">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Remote (other machine):" Width="160" VerticalAlignment="Center"/>
                        <ComboBox Width="180"
                                  ItemsSource="{Binding InputSources}"
                                  SelectedItem="{Binding SelectedRemoteInput}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:InputSourceOption">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Tracked USB Devices" FontWeight="SemiBold" FontSize="14"/>
                        <Button Content="Refresh" Command="{Binding RefreshDevicesCommand}" Padding="8,4"/>
                    </StackPanel>
                    <TextBlock Text="Select USB devices connected through the USB switch. When these devices appear, the monitor switches to local input." TextWrapping="Wrap" Foreground="Gray" FontSize="12"/>
                    <ItemsControl ItemsSource="{Binding AvailableDevices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:UsbDeviceItem">
                                <CheckBox Content="{Binding Description}" IsChecked="{Binding IsTracked}" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Command="{Binding SaveCommand}" Padding="24,8" Classes="accent"/>
        </StackPanel>
    </Grid>

</Window>
