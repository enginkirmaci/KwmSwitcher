<Window
    x:Class="KwmSwitcher.Views.SettingsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:KwmSwitcher.ViewModels"
    Title=""
    Width="800"
    Height="620"
    d:DesignHeight="620"
    d:DesignWidth="800"
    x:DataType="vm:SettingsViewModel"
    CanResize="False"
    ExtendClientAreaToDecorationsHint="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource ContentBackgroundBrush}" RowDefinitions="42,*">

        <Border
            Grid.Row="0"
            Background="{DynamicResource TitleBarBackgroundBrush}"
            BorderBrush="{DynamicResource TitleBarBorderBrush}"
            BorderThickness="0,0,0,1"
            IsHitTestVisible="True"
            PointerPressed="TitleBar_PointerPressed">
            <DockPanel Margin="16,0" VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SubtitleForegroundBrush}"
                    Text="Settings" />
            </DockPanel>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="24"
            RowDefinitions="*,Auto">

            <ScrollViewer Grid.Row="0">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Classes="section-card"
                        Margin="0,0,8,16">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="section-heading" Text="Monitor Input Protocol" />
                            <ComboBox
                                Width="280"
                                ItemsSource="{Binding InputProtocols}"
                                SelectedItem="{Binding SelectedInputProtocol}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InputProtocolOption">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Classes="section-hint" Text="Use LG if your monitor ignores standard DDC/CI input switching." />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="section-card"
                        Margin="8,0,0,16">
                        <StackPanel Spacing="16">
                            <TextBlock Classes="section-heading" Text="Monitor Input Sources" />
                            <StackPanel Spacing="6">
                                <TextBlock Classes="body-text" Text="Local (this machine):" />
                                <ComboBox
                                    Width="280"
                                    ItemsSource="{Binding InputSources}"
                                    SelectedItem="{Binding SelectedLocalInput}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:InputSourceOption">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="body-text" Text="Remote (other machine):" />
                                <ComboBox
                                    Width="280"
                                    ItemsSource="{Binding InputSources}"
                                    SelectedItem="{Binding SelectedRemoteInput}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:InputSourceOption">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Classes="section-card"
                        Margin="0,0,8,16">
                        <StackPanel Spacing="10">
                            <DockPanel>
                                <TextBlock
                                    Classes="section-heading"
                                    Text="Tracked USB Devices" />
                                <Button
                                    HorizontalAlignment="Right"
                                    Padding="12,6"
                                    Classes="action-ghost"
                                    Command="{Binding RefreshDevicesCommand}"
                                    Content="Refresh" />
                            </DockPanel>
                            <TextBlock Classes="section-hint" Text="Select USB devices connected through the USB switch. When these devices appear, the monitor switches to local input." />
                            <ItemsControl ItemsSource="{Binding AvailableDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:UsbDeviceItem">
                                        <CheckBox
                                            Margin="0,3"
                                            Content="{Binding Description}"
                                            IsChecked="{Binding IsTracked}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Spacing="0"
                        Margin="8,0,0,0">
                        <Border Classes="section-card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section-heading" Text="Target Monitor" />
                                <TextBlock Classes="section-hint" Text="Leave empty to try all monitors. Select your external monitor (e.g. LG) on laptops to avoid switching the built-in display." />
                                <ComboBox
                                    Width="280"
                                    IsEditable="True"
                                    ItemsSource="{Binding AvailableMonitors}"
                                    Text="{Binding SelectedTargetMonitor}" />
                            </StackPanel>
                        </Border>

                        <Border Classes="section-card">
                            <StackPanel Spacing="12">
                                <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}" />
                                <CheckBox Content="Auto-start on system startup" IsChecked="{Binding AutoStart}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <StackPanel
                Grid.Row="1"
                Margin="0,20,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Classes="action-ghost"
                    Command="{Binding CancelCommand}"
                    Content="Cancel" />
                <Button
                    Classes="action-primary"
                    Command="{Binding SaveCommand}"
                    Content="Save" />
            </StackPanel>
        </Grid>
    </Grid>

</Window>